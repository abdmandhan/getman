generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

enum BodyType {
  NONE
  JSON
  FORM_DATA
  URL_ENCODED
  RAW
  BINARY
}

enum RunScript {
  NONE
  PRE_REQUEST
  POST_REQUEST
}

enum AuthType {
  NONE
  BASIC
  BEARER
  API_KEY
}

enum RequestMethod {
  GET
  POST
  PUT
  DELETE
  PATCH
  OPTIONS
  HEAD
}

model Environment {
  id                   String                @id @default(uuid())
  name                 String
  description          String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  environmentVariables EnvironmentVariable[]
}

model EnvironmentVariable {
  id            String      @id @default(uuid())
  key           String
  value         String
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([environmentId, key])
}

model User {
  id              String           @id @default(uuid())
  name            String
  email           String           @unique
  password        String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  userCollections UserCollection[]
  folders         Folder[]
}

model Collection {
  id              String           @id @default(uuid())
  name            String
  description     String?
  requests        Request[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  userCollections UserCollection[]
  folders         Folder[]
}

model UserCollection {
  id           String     @id @default(uuid())
  userId       String
  collectionId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id])
  collection   Collection @relation(fields: [collectionId], references: [id])
}

model Authorization {
  id          String    @id @default(uuid())
  name        String
  authType    AuthType
  token       String?
  credentials Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  requests    Request[]
}

model Request {
  id              String        @id @default(uuid())
  name            String
  url             String
  method          RequestMethod
  description     String?
  headers         Json?
  body_type       BodyType      @default(NONE)
  body            Json?
  js_scripts      String? // used for storing javascript scripts for the request
  run_script      RunScript     @default(NONE)
  authorizationId String?

  folderId       String?
  folder         Folder?         @relation(fields: [folderId], references: [id])
  collectionId   String
  collection     Collection      @relation(fields: [collectionId], references: [id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  requestHeaders RequestHeader[]
  requestLogs    RequestLog[]
  authorization  Authorization?  @relation(fields: [authorizationId], references: [id])
}

model RequestHeader {
  id        String   @id @default(uuid())
  name      String
  value     String
  requestId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  request Request @relation(fields: [requestId], references: [id])
}

model RequestLog {
  id        String  @id @default(uuid())
  requestId String
  status    String
  response  Json?
  error     String?
  duration  Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  request Request @relation(fields: [requestId], references: [id])
}

model Folder {
  id           String   @id @default(uuid())
  name         String
  userId       String
  collectionId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  collection Collection @relation(fields: [collectionId], references: [id])
  user       User       @relation(fields: [userId], references: [id])
  requests   Request[]
}
